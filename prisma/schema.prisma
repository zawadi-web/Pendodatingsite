datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  phone            String?           @unique
  passwordHash     String?           // Optional for OAuth users
  googleId         String?           @unique // Google OAuth ID
  googleEmail      String?           // Email from Google
  role             String            @default("USER") // "USER" or "ADMIN"
  isSuspended      Boolean           @default(false)
  failedLoginAttempts Int             @default(0)
  lockoutUntil      DateTime?
  lastActiveAt     DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  profile          Profile?
  sentLikes        Like[]            @relation("LikesSent")
  receivedLikes    Like[]            @relation("LikesReceived")
  blocksSent       Block[]           @relation("BlocksSent")
  blocksReceived   Block[]           @relation("BlocksReceived")
  reportsSent      Report[]          @relation("ReportsSent")
  reportsReceived  Report[]          @relation("ReportsReceived")
  payments         Payment[]
  
  // Premium dating marketplace relations
  profileUnlocks     ProfileUnlock[] @relation("UserUnlocks")
  profileUnlockedBy  ProfileUnlock[] @relation("UserUnlockedBy")
  mediaUnlocks       MediaUnlock[]   @relation("MediaUserUnlocks")
  wallet             Wallet?
  subscriptions      Subscription[]
  coinPurchases      CoinPurchase[]
  ratingsGiven       Rating[]        @relation("RatingsGiven")
  ratingsReceived    Rating[]        @relation("RatingsReceived")
  reviewsGiven       Review[]        @relation("ReviewsGiven")
  reviewsReceived    Review[]        @relation("ReviewsReceived")
  chatRestriction    ChatRestriction?
  passwordResets     PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Profile {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  dob              DateTime
  gender           String    // "MALE", "FEMALE", "OTHER"
  preference       String    // "MALE", "FEMALE", "BOTH"
  bio              String?
  interests        String    // Comma-separated list of tags, e.g. "Travel,Music,Sports"
  location         String?   // City name, e.g. "Nairobi"
  latitude         Float?
  longitude        Float?
  photos           String    // JSON or comma-separated string of file paths, e.g. "/uploads/pic1.jpg"
  isVerified       Boolean   @default(false)
  isPremium        Boolean   @default(false)
  premiumUntil     DateTime?
  swipeCountToday  Int       @default(0)
  lastSwipeReset   DateTime  @default(now())
  instagram        String?
  facebook         String?
  telegram         String?
  prompts          String?   // JSON array of {question, answer} personality prompts
}


model Like {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  isLike    Boolean  // true for Like, false for Pass/Dislike
  createdAt DateTime @default(now())
  
  from      User     @relation("LikesSent", fields: [fromId], references: [id], onDelete: Cascade)
  to        User     @relation("LikesReceived", fields: [toId], references: [id], onDelete: Cascade)
  
  @@unique([fromId, toId])
  @@index([toId, isLike])
}

model Match {
  id        String   @id @default(cuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())
  messages  Message[]
  
  @@unique([user1Id, user2Id])
}

model Message {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId  String
  content   String
  imagePath String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([matchId, createdAt])
}

model Block {
  id         String   @id @default(cuid())
  blockerId  String
  blockedId  String
  createdAt  DateTime @default(now())
  
  blocker    User     @relation("BlocksSent", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked    User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)
  
  @@unique([blockerId, blockedId])
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  reportedId  String
  reason      String   // "FAKE", "SPAM", "ABUSE", "UNDERAGE", "OTHER"
  description String?
  status      String   @default("PENDING") // "PENDING", "RESOLVED", "DISMISSED"
  createdAt   DateTime @default(now())
  
  reporter    User     @relation("ReportsSent", fields: [reporterId], references: [id], onDelete: Cascade)
  reported    User     @relation("ReportsReceived", fields: [reportedId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount            Float
  phoneNumber       String
  checkoutRequestID String   @unique
  receiptNumber     String?
  status            String   @default("PENDING") // "PENDING", "SUCCESS", "FAILED"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, createdAt])
}

// Marketplace Models
model ProfileUnlock {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("UserUnlocks", fields: [userId], references: [id], onDelete: Cascade)
  targetUserId   String
  targetUser     User     @relation("UserUnlockedBy", fields: [targetUserId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([userId, targetUserId])
}

model MediaUnlock {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("MediaUserUnlocks", fields: [userId], references: [id], onDelete: Cascade)
  targetUserId   String
  mediaIndex     Int
  createdAt      DateTime @default(now())

  @@unique([userId, targetUserId, mediaIndex])
}

model Wallet {
  id             String        @id @default(cuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance        Float         @default(0.0)
  coins          Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transactions   Transaction[]
}

model Transaction {
  id             String   @id @default(cuid())
  walletId       String
  wallet         Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount         Float
  coins          Int      @default(0)
  type           String   // "DEPOSIT", "DEDUCTION", "COMMISSION", "REFUND", "PAYOUT"
  description    String
  status         String   @default("SUCCESS") // "PENDING", "SUCCESS", "FAILED", "REFUNDED"
  referenceId    String?  // links to checkoutRequestID or other reference
  createdAt      DateTime @default(now())
}

model Subscription {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planType       String   // "WEEKLY", "MONTHLY", "YEARLY"
  price          Float
  status         String   @default("ACTIVE") // "ACTIVE", "EXPIRED"
  activatedAt    DateTime @default(now())
  expiresAt      DateTime
  createdAt      DateTime @default(now())
}

model CoinPurchase {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coins             Int
  amount            Float
  checkoutRequestID String   @unique
  status            String   @default("PENDING") // "PENDING", "SUCCESS", "FAILED"
  createdAt         DateTime @default(now())
}

model Rating {
  id             String   @id @default(cuid())
  fromId         String
  from           User     @relation("RatingsGiven", fields: [fromId], references: [id], onDelete: Cascade)
  toId           String
  to             User     @relation("RatingsReceived", fields: [toId], references: [id], onDelete: Cascade)
  respect        Int      // 1-5
  communication  Int      // 1-5
  experience     Int      // 1-5
  reliability    Int      // 1-5
  createdAt      DateTime @default(now())

  @@unique([fromId, toId])
}

model Review {
  id             String   @id @default(cuid())
  fromId         String
  from           User     @relation("ReviewsGiven", fields: [fromId], references: [id], onDelete: Cascade)
  toId           String
  to             User     @relation("ReviewsReceived", fields: [toId], references: [id], onDelete: Cascade)
  comment        String
  createdAt      DateTime @default(now())
}

model ChatRestriction {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  warningsCount  Int      @default(0)
  lastWarningAt  DateTime @default(now())
  isBanned       Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model SystemConfig {
  id                 String   @id @default("default")
  saccoAccName       String   @default("Pendo SACCO Account")
  saccoAccNo         String   @default("174379") // Paybill number
  saccoInstructions  String   @default("1. Go to Lipa na M-Pesa. 2. Select Paybill. 3. Enter Business Number 174379. 4. Enter Account Number: Your Phone Number. 5. Enter Amount and PIN.")
  saccoEnabled       Boolean  @default(true)
  profileUnlockFee   Float    @default(200.0)
  mediaUnlockFee     Float    @default(100.0)
  weeklySubPrice     Float    @default(1000.0)
  monthlySubPrice    Float    @default(2500.0)
  yearlySubPrice     Float    @default(5000.0)
  coinPrice10        Float    @default(100.0)
  coinPrice50        Float    @default(450.0)
  coinPrice100       Float    @default(800.0)
  commissionFeePct   Float    @default(10.0)
  mpesaConsumerKey   String?
  mpesaConsumerSecret String?
  mpesaPasskey       String?
  mpesaShortCode     String?
  mpesaCallbackUrl   String?
  updatedAt          DateTime @updatedAt
}
